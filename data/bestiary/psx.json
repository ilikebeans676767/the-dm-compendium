    "size": "Medium",
    "type": "monstrosity",
    "alignment": "neutral evil",
    "armorClass": "14 (natural armor)",
    "hitPoints": "45 (6d8 + 18)",
    "speed": "walk 30 ft.",
    "abilities": {
      "str": 15,
      "dex": 14,
      "con": 16,
      "int": 6,
      "wis": 13,
      "cha": 9
    },
    "savingThrows": "",
    "skills": "perception: +3, stealth: +4",
    "senses": "darkvision 120 ft., passive Perception 13",
    "languages": "",
    "damageResistances": "bludgeoning, piercing, slashing from nonmagical weapons",
    "damageImmunities": "",
    "conditionImmunities": "",
    "challengeRating": "3",
    "traits": [
      {
        "name": "Sunlight Sensitivity",
        "entries": [
          "While in sunlight, the chupacabra has disadvantage on attack rolls, as well as on Wisdom (Perception) checks that rely on sight."
        ]
      }
    ],
    "spellcasting": [],
    "actions": [
      {
        "name": "Bite",
        "entries": [
          "*Melee Weapon Attack:* +4 to hit, reach 5 ft., one target. *Hit:* 7 (2d4 + 2) piercing damage. If the target is a creature, it must succeed on a DC 13 Strength saving throw or be knocked prone."
        ]
      },
      {
        "name": "Drain Blood",
        "entries": [
          "*Melee Weapon Attack:* +4 to hit, reach 5 ft., one creature that is prone, incapacitated, or restrained. *Hit:* 5 (1d6 + 2) necrotic damage. The target must succeed on a DC 13 Constitution saving throw or its hit point maximum is reduced by an amount equal to the damage taken, and the chupacabra regains hit points equal to that amount. The reduction lasts until the target finishes a long rest. The target dies if this effect reduces its hit point maximum to 0."
        ]
      }
    ],
    "bonusActions": [],
    "reactions": [
      {
        "name": "Pin",
        "entries": [
          "If a creature within 5 feet of the chupacabra stands up, the chupacabra can use its reaction to make a bite attack."
        ]
      }
    ],
